# .env.example
# Copy to .env and fill in your values.
# This is the same .env Immich uses — no need to duplicate if you already have one.

DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE_NAME=immich
# DB_HOST defaults to 'database' (Immich's postgres service name on the shared network)
# DB_PORT defaults to 5432
