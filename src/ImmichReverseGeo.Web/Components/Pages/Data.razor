@page "/data"
@rendermode InteractiveServer
@inject GadmDivisionCacheService GadmCache
@inject OvertureDivisionCacheService OvertureCache
@inject SkippedAssetsRepository Skipped

<h2>Data Management</h2>

<section class="settings-card">
    <h3>Management Sections</h3>
    <p class="section-intro">Use this page to manage downloaded administrative caches and reverse geo maintenance tools.</p>
    <div class="data-grid">
        <a class="data-link-card" href="/data/reset-geo-data">
            <span class="data-card-title">Reset Immich Geo Data</span>
            <span class="data-card-meta">Clear only reverse geo city, state, and country fields</span>
        </a>
        <a class="data-link-card" href="/data/geoboundaries">
            <span class="data-card-title">Administrative Areas</span>
            <span class="data-card-meta">@_overtureDivisionCountryCount Overture cache(s), @_gadmDivisionCountryCount GADM cache(s)</span>
        </a>
    </div>
</section>

<section class="settings-card">
    <h3>Skipped Assets</h3>
    <p class="section-intro">Assets whose GPS coordinates fell outside all country boundaries (ocean, unmapped territories,
       or simplified-boundary false negatives near coastlines). These are permanently excluded from processing
       to prevent endless retries. Clear the list to re-attempt them on the next run.</p>
    <p>@_skippedCount asset(s) permanently skipped.</p>
    <div class="btn-row">
        <button @onclick="ClearSkipped" class="btn btn-secondary" disabled="@(_skippedCount == 0)">
            Clear Skip List
        </button>
    </div>
    @if (_skipClearResult is not null)
    {
        <p class="alert alert-success">@_skipClearResult</p>
    }
</section>

@code {
    private long _skippedCount;
    private string? _skipClearResult;
    private int _overtureDivisionCountryCount;
    private int _gadmDivisionCountryCount;

    protected override async Task OnInitializedAsync()
    {
        await RefreshPageState();
    }

    private async Task ClearSkipped()
    {
        var prev = _skippedCount;
        await Skipped.ClearAllAsync();
        _skippedCount = 0;
        _skipClearResult = $"Cleared {prev:N0} skipped asset(s). They will be retried on the next run.";
    }

    private async Task RefreshPageState()
    {
        _overtureDivisionCountryCount = OvertureCache.GetStatus().Count;
        _gadmDivisionCountryCount = GadmCache.GetStatus().Count;
        try
        {
            _skippedCount = await Skipped.GetCountAsync();
        }
        catch
        {
            /* SQLite not yet initialised — ignore */
        }
    }
}
