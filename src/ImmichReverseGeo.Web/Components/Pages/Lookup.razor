@page "/lookup"
@rendermode InteractiveServer
@inject GadmDivisionsService GadmDivisions
@inject GadmDivisionCacheService GadmCache
@inject OverturePlacesService Overture
@inject OvertureDivisionCacheService OvertureCache
@inject OvertureDivisionsService OvertureDivisions
@inject ConfigService Config
@inject CityResolverProfileCatalogService CityResolverCatalog

<h2>Coordinate Lookup</h2>
<p class="page-desc">Enter coordinates to inspect how the Overture-backed resolver behaves.</p>

<div class="lookup-form">
    <div class="lookup-paste-row">
        <label for="paste">Paste coordinates</label>
        <input id="paste" type="text" class="paste-input"
               placeholder="47.4647, 8.5492 or N47.4647 E8.5492"
               @oninput="OnPasteInput" />
        @if (_parseError is not null)
        {
            <span class="parse-error">@_parseError</span>
        }
    </div>
    <div class="lookup-coord-row">
        <div class="input-group">
            <label for="lat">Latitude</label>
            <input id="lat" type="number" step="any" placeholder="47.4647"
                   @bind="_lat" @bind:event="oninput" class="coord-input" />
        </div>
        <div class="input-group">
            <label for="lon">Longitude</label>
            <input id="lon" type="number" step="any" placeholder="8.5492"
                   @bind="_lon" @bind:event="oninput" class="coord-input" />
        </div>
        <button class="btn btn-primary" @onclick="RunLookup" disabled="@_running">
            @(_running ? "Looking upâḊ" : "Lookup")
        </button>
    </div>
    <div class="lookup-options-row">
        <label class="checkbox-label">
            <input type="checkbox" @bind="_includeAirportInfrastructure" />
            <span>Include bundled airport infrastructure lookup</span>
        </label>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_includeLivePlaces" />
            <span>Include live Overture Places lookup (slower)</span>
        </label>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_preferGadmAdministrativeAreas" />
            <span>Prefer cached GADM administrative areas (experimental, non-commercial)</span>
        </label>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}

@if (_running || _lookupStatus is not null)
{
    <div class="settings-card">
        <h3>Lookup Status</h3>
        <p class="section-intro">
            @(_running ? "The lookup is running. Current step:" : "Last lookup activity:")
        </p>
        <p class="run-info activity">@(_lookupStatus ?? "Preparing lookup...")</p>
    </div>
}

@if (_result is not null)
{
    <div class="lookup-results">
        <div class="result-card @(_result.Iso3 is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Country â Overture Bundled Cache</span>
                <span class="result-badge @(_result.Iso3 is not null ? "badge-found" : "badge-miss")">
                    @(_result.Iso3 is not null ? "found" : "no match")
                </span>
            </div>
            @if (_result.Iso3 is not null)
            {
                <div class="result-row"><span class="result-key">Name</span><span class="result-val">@_result.CountryName</span></div>
                <div class="result-row"><span class="result-key">ISO3</span><span class="result-val mono">@_result.Iso3</span></div>
                <div class="result-row"><span class="result-key">Alpha-2</span><span class="result-val mono">@(_result.Alpha2 ?? "â")</span></div>
            }
            else
            {
                <div class="result-note">No bundled Overture country division matched this point.</div>
            }
        </div>

        <div class="result-card @(_result.OvertureDivisionState is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Administrative Areas â Cached Overture Divisions</span>
                <span class="result-badge @(_result.Iso3 is null ? "badge-miss" : _result.OvertureDivisionState is not null || _result.OvertureDivisionCity is not null ? "badge-found" : "badge-miss")">
                    @(_result.Iso3 is null ? "skipped" : _result.OvertureDivisionState is not null || _result.OvertureDivisionCity is not null ? "found" : "no match")
                </span>
            </div>
            @if (_result.Iso3 is null)
            {
                <div class="result-note">Country lookup must succeed before per-country division caches can be queried.</div>
            }
            else
            {
                <div class="result-row"><span class="result-key">State</span><span class="result-val">@(_result.OvertureDivisionState ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Resolved City</span><span class="result-val">@(_result.OvertureDivisionCity ?? "â")</span></div>
                <div class="result-row"><span class="result-key">City Resolver Profile</span><span class="result-val">@(_result.CityResolverSummary ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Area</span><span class="result-val">@(_result.OvertureDivision?.Name ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Subtype</span><span class="result-val">@(_result.OvertureDivision?.SubType ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Admin Level</span><span class="result-val">@(_result.OvertureDivision?.AdminLevel?.ToString() ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Cache</span><span class="result-val">@(_result.OvertureDivisionCacheReady ? "ready" : "missing")</span></div>
                <div class="result-note">Resolved City uses the configured country-aware profile. Raw Best Area shows the strongest single cached division candidate before that policy is applied.</div>
            }
        </div>

        <div class="result-card @(_result.GadmDivisionState is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Administrative Areas â Cached GADM</span>
                <span class="result-badge @(_result.Iso3 is null ? "badge-miss" : !_result.GadmEnabled ? "badge-miss" : _result.GadmDivisionState is not null || _result.GadmDivisionCity is not null ? "badge-found" : "badge-miss")">
                    @(_result.Iso3 is null ? "skipped" : !_result.GadmEnabled ? "disabled" : _result.GadmDivisionState is not null || _result.GadmDivisionCity is not null ? "found" : "no match")
                </span>
            </div>
            @if (!_result.GadmEnabled)
            {
                <div class="result-note">Cached GADM lookup is disabled for this run.</div>
            }
            else if (_result.Iso3 is null)
            {
                <div class="result-note">Country lookup must succeed before the per-country GADM cache can be queried.</div>
            }
            else
            {
                <div class="result-row"><span class="result-key">State</span><span class="result-val">@(_result.GadmDivisionState ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Resolved City</span><span class="result-val">@(_result.GadmDivisionCity ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Area</span><span class="result-val">@(_result.GadmDivision?.Name ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Type</span><span class="result-val">@(_result.GadmDivision?.EnglishType ?? _result.GadmDivision?.LocalType ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Raw Best Admin Level</span><span class="result-val">@(_result.GadmDivision?.AdminLevel.ToString() ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Cache</span><span class="result-val">@(_result.GadmDivisionCacheReady ? "ready" : "missing")</span></div>
                <div class="result-note">This experimental path still uses bundled Overture country detection to decide which country cache to load first.</div>
            }
        </div>

        <div class="result-card @(_result.OvertureInfrastructure is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Airport Infrastructure â Bundled Overture</span>
                <span class="result-badge @(_result.Iso3 is null || !_result.AirportInfrastructureEnabled ? "badge-miss" : _result.OvertureInfrastructure is not null ? "badge-found" : "badge-miss")">
                    @(_result.Iso3 is null ? "skipped" : !_result.AirportInfrastructureEnabled ? "disabled" : _result.OvertureInfrastructure is not null ? "found" : "no match")
                </span>
            </div>
            @if (!_result.AirportInfrastructureEnabled)
            {
                <div class="result-note">Bundled airport infrastructure lookup is disabled for this run.</div>
            }
            else if (_result.OvertureInfrastructure is not null)
            {
                <div class="result-row"><span class="result-key">Name</span><span class="result-val">@_result.OvertureInfrastructure.Name</span></div>
                <div class="result-row"><span class="result-key">Subtype</span><span class="result-val">@(_result.OvertureInfrastructure.SubType ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Class</span><span class="result-val">@(_result.OvertureInfrastructure.ClassName ?? "â")</span></div>
                <div class="result-row"><span class="result-key">BBox Contains Point</span><span class="result-val">@(_result.OvertureInfrastructure.BoundingBoxContainsPoint ? "yes" : "no")</span></div>
                <div class="result-row"><span class="result-key">Geometry Contains Point</span><span class="result-val">@(_result.OvertureInfrastructure.GeometryContainsPoint ? "yes" : "no")</span></div>
                <div class="result-row"><span class="result-key">Distance</span><span class="result-val">@((int)_result.OvertureInfrastructure.DistanceMetres) m</span></div>
            }
            else if (_result.Iso3 is not null)
            {
                <div class="result-note">No cached Overture airport infrastructure feature matched this point.</div>
            }
            @if (_result.Iso3 is not null && _result.AirportInfrastructureEnabled)
            {
                <div class="result-note">Ranking prefers better airport class, then real geometry matches, then bbox matches, then distance.</div>
            }
        </div>

        <div class="result-card @(_result.OverturePoi is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Overture Places â Live Lookup</span>
                <span class="result-badge @(!_result.LivePlacesEnabled || _result.Iso3 is null ? "badge-miss" : _result.OvertureDiagnostics?.Error is not null ? "badge-miss" : _result.OverturePoi is not null ? "badge-found" : "badge-miss")">
                    @(!_result.LivePlacesEnabled || _result.Iso3 is null ? "skipped" : _result.OvertureDiagnostics?.Error is not null ? "error" : _result.OverturePoi is not null ? "found" : "no match")
                </span>
            </div>
            @if (!_result.LivePlacesEnabled)
            {
                <div class="result-note">Live Overture Places lookup is disabled for this run.</div>
            }
            else if (_result.OverturePoi is not null)
            {
                <div class="result-row"><span class="result-key">Name</span><span class="result-val">@_result.OverturePoi.Name</span></div>
                <div class="result-row"><span class="result-key">Category</span><span class="result-val">@(_result.OverturePoi.Category ?? _result.OverturePoi.BasicCategory ?? "â")</span></div>
                <div class="result-row"><span class="result-key">Confidence</span><span class="result-val">@_result.OverturePoi.Confidence.ToString("0.00")</span></div>
                <div class="result-row"><span class="result-key">Status</span><span class="result-val">@(_result.OverturePoi.OperatingStatus ?? "â")</span></div>
                <div class="result-row"><span class="result-key">BBox Contains Point</span><span class="result-val">@(_result.OverturePoi.BoundingBoxContainsPoint ? "yes" : "no")</span></div>
                <div class="result-row"><span class="result-key">Sources</span><span class="result-val">@DescribeSources(_result.OverturePoi.Sources)</span></div>
                <div class="result-row"><span class="result-key">Distance</span><span class="result-val">@((int)_result.OverturePoi.DistanceMetres) m</span></div>
            }
            else if (_result.OvertureDiagnostics?.Error is not null)
            {
                <div class="result-note">Live Overture Places lookup failed: @_result.OvertureDiagnostics.Error</div>
            }
            else if (_result.Iso3 is not null)
            {
                <div class="result-note">No live Overture place matched inside the current search window.</div>
            }
            @if (_result.LivePlacesEnabled && _result.Iso3 is not null)
            {
                <div class="result-note">Confidence below 0.90 is filtered out. Among the remaining candidates, ranking prefers active/open places, then bbox containment, then distance.</div>
            }
        </div>

        <div class="result-card final-card @(_result.FinalCity is not null ? "found" : "not-found")">
            <div class="result-header">
                <span class="result-source">Final output (what would be written to Immich)</span>
                <span class="result-badge @(_result.FinalCity is not null ? "badge-found" : "badge-miss")">
                    @(_result.FinalCity is not null ? "complete" : "incomplete â would not write")
                </span>
            </div>
            <div class="result-row"><span class="result-key">City</span><span class="result-val">@(_result.FinalCity ?? "â")</span></div>
            <div class="result-row"><span class="result-key">City Source</span><span class="result-val">@(_result.FinalCitySource ?? "â")</span></div>
            <div class="result-row"><span class="result-key">State</span><span class="result-val">@(_result.FinalState ?? "â")</span></div>
            <div class="result-row"><span class="result-key">State Source</span><span class="result-val">@(_result.FinalStateSource ?? "â")</span></div>
            <div class="result-row"><span class="result-key">Country</span><span class="result-val">@(_result.CountryName ?? "â")</span></div>
            <div class="result-row"><span class="result-key">Country Source</span><span class="result-val">@(_result.FinalCountrySource ?? "â")</span></div>
        </div>

        <div class="result-card trace-card">
            <div class="result-header">
                <span class="result-source">Lookup Trace</span>
                <span class="result-badge badge-found">debug</span>
            </div>
            <details class="trace-details" @attributes="GetDetailsAttributes(_expandTrace)">
                <summary class="trace-summary">Trace Lines (@_result.Trace.Count)</summary>
                <div class="trace-section">
                    @foreach (var line in _result.Trace)
                    {
                        <div class="trace-line">@line</div>
                    }
                </div>
            </details>
            @if (_result.OvertureInfrastructureDiagnostics is not null)
            {
                <details class="trace-details">
                    <summary class="trace-summary">Cached Infrastructure Candidates (@_result.OvertureInfrastructureDiagnostics.Candidates.Count considered, release @(_result.OvertureInfrastructureDiagnostics.Release ?? "unknown"))</summary>
                    <div class="trace-section">
                        @if (_result.OvertureInfrastructureDiagnostics.Error is not null)
                        {
                            <div class="trace-line">Infrastructure error: @_result.OvertureInfrastructureDiagnostics.Error</div>
                        }
                        else if (_result.OvertureInfrastructureDiagnostics.Candidates.Count == 0)
                        {
                            <div class="trace-line">No cached airport infrastructure candidates were returned.</div>
                        }
                        else
                        {
                            @foreach (var candidate in SortInfrastructureCandidates(_result.OvertureInfrastructureDiagnostics.Candidates))
                            {
                                <div class="trace-candidate @(candidate.Selected ? "selected" : null)">
                                    <div class="trace-candidate-main">
                                        <span class="trace-name">@candidate.Name</span>
                                        <span class="trace-meta">@((int)candidate.DistanceMetres) m</span>
                                        <span class="trace-meta">bbox @(candidate.BoundingBoxContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">geom @(candidate.GeometryContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">@((candidate.SubType ?? candidate.FeatureType ?? "unknown").ToLowerInvariant())</span>
                                    </div>
                                    <div class="trace-candidate-sub">
                                        <span class="mono">@candidate.Id</span>
                                        <span>@(candidate.ClassName ?? "unclassified")</span>
                                        <span>@candidate.Decision</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </details>
            }
            @if (_result.OvertureDivisionDiagnostics is not null)
            {
                <details class="trace-details">
                    <summary class="trace-summary">Cached Division Areas (@_result.OvertureDivisionDiagnostics.Candidates.Count considered, release @(_result.OvertureDivisionDiagnostics.Release ?? "unknown"))</summary>
                    <div class="trace-section">
                        @if (_result.OvertureDivisionDiagnostics.Error is not null)
                        {
                            <div class="trace-line">Division error: @_result.OvertureDivisionDiagnostics.Error</div>
                        }
                        else if (_result.OvertureDivisionDiagnostics.Candidates.Count == 0)
                        {
                            <div class="trace-line">No cached division areas were returned for the point.</div>
                        }
                        else
                        {
                            @foreach (var candidate in SortDivisionCandidates(_result.OvertureDivisionDiagnostics.Candidates))
                            {
                                <div class="trace-candidate @(candidate.Selected ? "selected" : null)">
                                    <div class="trace-candidate-main">
                                        <span class="trace-name">@candidate.Name</span>
                                        <span class="trace-meta">@((candidate.SubType ?? "unknown").ToLowerInvariant())</span>
                                        <span class="trace-meta">admin @((candidate.AdminLevel?.ToString()) ?? "â")</span>
                                        <span class="trace-meta">bbox @(candidate.BoundingBoxContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">geom @(candidate.GeometryContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">territorial @(candidate.IsTerritorial ? "yes" : "no")</span>
                                    </div>
                                    <div class="trace-candidate-sub">
                                        <span class="mono">@candidate.Id</span>
                                        <span>@(candidate.ClassName ?? "unclassified")</span>
                                        <span>@(candidate.Country ?? "â")</span>
                                        <span>bbox area @candidate.BoundingBoxArea.ToString("0.######")</span>
                                        <span>@candidate.Decision</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </details>
            }
            @if (_result.GadmDivisionDiagnostics is not null)
            {
                <details class="trace-details">
                    <summary class="trace-summary">Cached GADM Areas (@_result.GadmDivisionDiagnostics.Candidates.Count considered, version @(_result.GadmDivisionDiagnostics.Version ?? "unknown"))</summary>
                    <div class="trace-section">
                        @if (_result.GadmDivisionDiagnostics.Error is not null)
                        {
                            <div class="trace-line">GADM error: @_result.GadmDivisionDiagnostics.Error</div>
                        }
                        else if (_result.GadmDivisionDiagnostics.Candidates.Count == 0)
                        {
                            <div class="trace-line">No cached GADM areas were returned for the point.</div>
                        }
                        else
                        {
                            @foreach (var candidate in SortGadmCandidates(_result.GadmDivisionDiagnostics.Candidates))
                            {
                                <div class="trace-candidate @(candidate.Selected ? "selected" : null)">
                                    <div class="trace-candidate-main">
                                        <span class="trace-name">@candidate.Name</span>
                                        <span class="trace-meta">level @candidate.AdminLevel</span>
                                        <span class="trace-meta">bbox @(candidate.BoundingBoxContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">geom @(candidate.GeometryContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">@((candidate.EnglishType ?? candidate.LocalType ?? "unknown").ToLowerInvariant())</span>
                                    </div>
                                    <div class="trace-candidate-sub">
                                        <span class="mono">@candidate.Id</span>
                                        <span>bbox area @candidate.BoundingBoxArea.ToString("0.######")</span>
                                        <span>@candidate.Decision</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </details>
            }
            @if (_result.OvertureDiagnostics is not null)
            {
                <details class="trace-details">
                    <summary class="trace-summary">Live Overture Places (@_result.OvertureDiagnostics.Candidates.Count considered, release @(_result.OvertureDiagnostics.Release ?? "unknown"))</summary>
                    <div class="trace-section">
                        @if (_result.OvertureDiagnostics.Error is not null)
                        {
                            <div class="trace-line">Places error: @_result.OvertureDiagnostics.Error</div>
                        }
                        else if (_result.OvertureDiagnostics.Candidates.Count == 0)
                        {
                            <div class="trace-line">No live Overture places were returned inside the search window.</div>
                        }
                        else
                        {
                            @foreach (var candidate in SortPlaceCandidates(_result.OvertureDiagnostics.Candidates))
                            {
                                <div class="trace-candidate @(candidate.Selected ? "selected" : null)">
                                    <div class="trace-candidate-main">
                                        <span class="trace-name">@candidate.Name</span>
                                        <span class="trace-meta">@((int)candidate.DistanceMetres) m</span>
                                        <span class="trace-meta">conf @candidate.Confidence.ToString("0.00")</span>
                                        <span class="trace-meta">bbox @(candidate.BoundingBoxContainsPoint ? "yes" : "no")</span>
                                        <span class="trace-meta">@((candidate.OperatingStatus ?? "unknown").ToLowerInvariant())</span>
                                    </div>
                                    <div class="trace-candidate-sub">
                                        <span class="mono">@candidate.Id</span>
                                        <span>@(candidate.Category ?? candidate.BasicCategory ?? "uncategorized")</span>
                                        <span>@DescribeSources(candidate.Sources)</span>
                                        <span>@candidate.Decision</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </details>
            }
        </div>
    </div>
}

@code {
    private double _lat;
    private double _lon;
    private string? _parseError;
    private bool _running;
    private bool _expandTrace = true;
    private bool _includeAirportInfrastructure = true;
    private bool _includeLivePlaces;
    private bool _preferGadmAdministrativeAreas;
    private IReadOnlyList<string> _gadmCandidateCodes = [];
    private string? _lookupStatus;
    private string? _error;
    private LookupResult? _result;

    protected override async Task OnInitializedAsync()
    {
        var cfg = await Config.GetConfigAsync();
        _includeAirportInfrastructure = cfg.Processing.UseAirportInfrastructure;
    }

    private void OnPasteInput(ChangeEventArgs e)
    {
        var text = e.Value?.ToString() ?? string.Empty;
        _parseError = null;

        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        if (TryParseCoordinates(text, out var lat, out var lon))
        {
            _lat = lat;
            _lon = lon;
        }
        else
        {
            _parseError = "Could not parse coordinates";
        }
    }

    private static bool TryParseCoordinates(string text, out double lat, out double lon)
    {
        lat = lon = 0;
        text = text.Trim();
        text = System.Text.RegularExpressions.Regex.Replace(text, @"[,;|]+", " ");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ").Trim();

        var dms = System.Text.RegularExpressions.Regex.Match(text,
            @"(\d+)[ÂḞd\s]\s*(\d+)['']\s*(\d+(?:\.\d+)?)['""s]?\s*([NSns])\s+" +
            @"(\d+)[ÂḞd\s]\s*(\d+)['']\s*(\d+(?:\.\d+)?)['""s]?\s*([EWew])");
        if (dms.Success)
        {
            lat = DmsToDecimal(dms.Groups[1], dms.Groups[2], dms.Groups[3], dms.Groups[4].Value);
            lon = DmsToDecimal(dms.Groups[5], dms.Groups[6], dms.Groups[7], dms.Groups[8].Value);
            return true;
        }

        var dir = System.Text.RegularExpressions.Regex.Match(text,
            @"([NSns])\s*(\d+(?:\.\d+)?)\s+([EWew])\s*(\d+(?:\.\d+)?)");
        if (!dir.Success)
        {
            dir = System.Text.RegularExpressions.Regex.Match(text,
                @"(\d+(?:\.\d+)?)\s*([NSns])\s+(\d+(?:\.\d+)?)\s*([EWew])");
            if (dir.Success)
            {
                lat = ApplyDirection(double.Parse(dir.Groups[1].Value, System.Globalization.CultureInfo.InvariantCulture), dir.Groups[2].Value);
                lon = ApplyDirection(double.Parse(dir.Groups[3].Value, System.Globalization.CultureInfo.InvariantCulture), dir.Groups[4].Value);
                return true;
            }
        }
        else
        {
            lat = ApplyDirection(double.Parse(dir.Groups[2].Value, System.Globalization.CultureInfo.InvariantCulture), dir.Groups[1].Value);
            lon = ApplyDirection(double.Parse(dir.Groups[4].Value, System.Globalization.CultureInfo.InvariantCulture), dir.Groups[3].Value);
            return true;
        }

        var kv = System.Text.RegularExpressions.Regex.Match(text,
            @"lat\s*=\s*(-?\d+(?:\.\d+)?)\s+lon\s*=\s*(-?\d+(?:\.\d+)?)",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (kv.Success
            && double.TryParse(kv.Groups[1].Value, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lat)
            && double.TryParse(kv.Groups[2].Value, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lon))
        {
            return true;
        }

        var parts = text.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2
            && double.TryParse(parts[0], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var a)
            && double.TryParse(parts[1], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var b))
        {
            lat = a;
            lon = b;
            return true;
        }

        return false;
    }

    private static double DmsToDecimal(System.Text.RegularExpressions.Group deg, System.Text.RegularExpressions.Group min, System.Text.RegularExpressions.Group sec, string direction)
    {
        var v = double.Parse(deg.Value) + double.Parse(min.Value) / 60.0
              + double.Parse(sec.Value, System.Globalization.CultureInfo.InvariantCulture) / 3600.0;
        return ApplyDirection(v, direction);
    }

    private static double ApplyDirection(double value, string direction)
    {
        return direction.ToUpperInvariant() is "S" or "W" ? -value : value;
    }

    private async Task RunLookup()
    {
        _error = null;
        _result = null;
        _running = true;
        _lookupStatus = "Preparing lookup...";
        StateHasChanged();

        try
        {
            await RunLookupCore();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _lookupStatus = $"Lookup failed: {ex.Message}";
        }
        finally
        {
            _lookupStatus ??= "Lookup finished.";
            _running = false;
        }
    }

    private async Task RunLookupCore()
    {
        var r = new LookupResult
        {
            AirportInfrastructureEnabled = _includeAirportInfrastructure,
            LivePlacesEnabled = _includeLivePlaces,
            GadmEnabled = _preferGadmAdministrativeAreas
        };

        await UpdateLookupStatusAsync("Checking bundled Overture country coverage...");
        (r.Iso3, r.CountryName, r.Alpha2) = await OvertureDivisions.FindBundledCountryAsync(_lat, _lon);
        if (r.Iso3 is null)
        {
            r.Trace.Add("Country lookup: bundled Overture country divisions found no match.");
            await UpdateLookupStatusAsync("Bundled Overture country lookup found no match.");
            _result = r;
            StateHasChanged();
            return;
        }

        r.Trace.Add($"Country matched from bundled Overture divisions: {r.CountryName} ({r.Iso3}, {r.Alpha2 ?? "no alpha-2"})");
        await UpdateLookupStatusAsync($"Country resolved as {r.CountryName} ({r.Iso3}).");

        var cfg = await Config.GetConfigAsync();
        var cityResolverProfile = CityResolverCatalog.GetProfile(cfg.Processing.CityResolver, r.Iso3);
        r.CityResolverSummary = $"{string.Join(" > ", cityResolverProfile.PreferredSubtypes)} ({cityResolverProfile.TieBreakMode})";
        r.Trace.Add($"City resolver profile: {r.CityResolverSummary}");

        var ensureDivisionTask = EnsureDivisionCacheAsync(r);
        _gadmCandidateCodes = r.Iso3 is not null
            ? GadmCountryFallbackCatalog.ExpandCandidateCodes(r.Iso3)
            : [];

        var ensureGadmTask = EnsureGadmCacheAsync(r, _gadmCandidateCodes);
        Task<OvertureInfrastructureLookupDiagnostics>? infrastructureTask = null;
        if (_includeAirportInfrastructure)
        {
            infrastructureTask = Overture.FindNearestInfrastructureWithDiagnosticsAsync(_lat, _lon, r.Iso3);
        }
        Task<OvertureLookupDiagnostics>? livePlacesTask = null;
        if (_includeLivePlaces)
        {
            livePlacesTask = Overture.FindNearestPlaceWithDiagnosticsAsync(_lat, _lon, r.Alpha2);
        }

        await ensureDivisionTask;
        await UpdateLookupStatusAsync("Querying cached Overture administrative areas...");
        r.OvertureDivisionDiagnostics = await OvertureDivisions.FindContainingDivisionAreasAsync(_lat, _lon, r.Alpha2, r.Iso3);
        r.OvertureDivision = r.OvertureDivisionDiagnostics.BestMatch;
        r.OvertureDivisionState = OvertureDivisionsLogic.SelectStateName(r.OvertureDivisionDiagnostics.Candidates);
        r.OvertureDivisionCity = OvertureDivisionsLogic.SelectCityName(r.OvertureDivisionDiagnostics.Candidates, cityResolverProfile);
        r.Trace.Add(r.OvertureDivisionDiagnostics.Error is not null
            ? $"Overture division lookup failed: {r.OvertureDivisionDiagnostics.Error}"
            : $"Overture division admin resolution: state={r.OvertureDivisionState ?? "â"}, city={r.OvertureDivisionCity ?? "â"}");

        await ensureGadmTask;
        if (_preferGadmAdministrativeAreas && r.GadmDivisionCacheReady)
        {
            await UpdateLookupStatusAsync($"Querying cached GADM administrative areas across {string.Join(", ", _gadmCandidateCodes)}...");
            r.GadmDivisionDiagnostics = await GadmDivisions.FindContainingDivisionAreasAsync(_lat, _lon, _gadmCandidateCodes);
            r.GadmDivision = r.GadmDivisionDiagnostics.BestMatch;
            r.GadmDivisionState = GadmDivisionsLogic.SelectStateName(r.GadmDivisionDiagnostics.Candidates);
            r.GadmDivisionCity = GadmDivisionsLogic.SelectCityName(r.GadmDivisionDiagnostics.Candidates);
            r.Trace.Add(r.GadmDivisionDiagnostics.Error is not null
                ? $"GADM lookup failed: {r.GadmDivisionDiagnostics.Error}"
                : $"GADM admin resolution: state={r.GadmDivisionState ?? "â"}, city={r.GadmDivisionCity ?? "â"} (candidates: {string.Join(", ", _gadmCandidateCodes)})");
        }
        else if (_preferGadmAdministrativeAreas)
        {
            r.Trace.Add("GADM lookup skipped because the cache is unavailable.");
        }
        else
        {
            r.Trace.Add("GADM lookup skipped.");
        }

        if (infrastructureTask is not null)
        {
            await UpdateLookupStatusAsync("Querying bundled airport infrastructure...");
            r.OvertureInfrastructureDiagnostics = await infrastructureTask;
            r.OvertureInfrastructure = r.OvertureInfrastructureDiagnostics.BestMatch;
            r.Trace.Add(r.OvertureInfrastructureDiagnostics.Error is not null
                ? $"Overture infrastructure lookup failed: {r.OvertureInfrastructureDiagnostics.Error}"
                : r.OvertureInfrastructure is not null
                    ? $"Overture infrastructure winner: {r.OvertureInfrastructure.Name} at {(int)r.OvertureInfrastructure.DistanceMetres} m (bbox={(r.OvertureInfrastructure.BoundingBoxContainsPoint ? "yes" : "no")}, geom={(r.OvertureInfrastructure.GeometryContainsPoint ? "yes" : "no")})"
                    : "Overture infrastructure lookup: no in-range match");
        }
        else
        {
            r.Trace.Add("Overture infrastructure lookup skipped.");
        }

        if (livePlacesTask is not null)
        {
            await UpdateLookupStatusAsync("Querying live Overture Places...");
            r.OvertureDiagnostics = await livePlacesTask;
            r.OverturePoi = r.OvertureDiagnostics.BestMatch;
            r.Trace.Add(r.OvertureDiagnostics.Error is not null
                ? $"Overture Places lookup failed: {r.OvertureDiagnostics.Error}"
                : r.OverturePoi is not null
                    ? $"Overture Places winner: {r.OverturePoi.Name} at {(int)r.OverturePoi.DistanceMetres} m (conf={r.OverturePoi.Confidence:0.00}, status={r.OverturePoi.OperatingStatus ?? "unknown"})"
                    : "Overture Places lookup: no in-range match");
        }
        else
        {
            r.Trace.Add("Overture Places lookup skipped.");
        }

        var adminState = _preferGadmAdministrativeAreas && r.GadmDivisionState is not null
            ? r.GadmDivisionState
            : r.OvertureDivisionState;
        var adminStateSource = _preferGadmAdministrativeAreas && r.GadmDivisionState is not null
            ? "Cached GADM divisions"
            : r.OvertureDivisionState is not null
                ? "Cached Overture divisions"
                : null;
        var adminCity = _preferGadmAdministrativeAreas && r.GadmDivisionCity is not null
            ? r.GadmDivisionCity
            : r.OvertureDivisionCity;
        var adminCitySource = _preferGadmAdministrativeAreas && r.GadmDivisionCity is not null
            ? "Cached GADM divisions"
            : r.OvertureDivisionCity is not null
                ? "Cached Overture divisions"
                : null;

        r.FinalState = adminState;
        r.FinalStateSource = adminStateSource;
        r.FinalCountrySource = r.CountryName is not null ? "Bundled Overture country divisions" : null;
        var city = r.OvertureInfrastructure?.GeometryContainsPoint == true
            ? r.OvertureInfrastructure.Name
            : adminCity ?? r.OvertureInfrastructure?.Name;
        r.FinalCitySource = r.OvertureInfrastructure?.GeometryContainsPoint == true
            ? "Bundled airport infrastructure (geometry match)"
            : adminCitySource is not null
                ? adminCitySource
                : r.OvertureInfrastructure?.Name is not null
                    ? "Bundled airport infrastructure (fallback)"
                    : null;
        if (city is null && r.FinalState is not null)
        {
            city = r.FinalState;
            r.FinalCitySource = r.FinalStateSource;
        }
        else if (city is null && r.CountryName is not null)
        {
            city = r.CountryName;
            r.FinalCitySource = r.FinalCountrySource;
        }

        r.FinalCity = city;
        r.Trace.Add($"Final city decision: {r.FinalCity ?? "no result"}");
        await UpdateLookupStatusAsync("Lookup finished.");

        _result = r;
        StateHasChanged();
    }

    private async Task EnsureDivisionCacheAsync(LookupResult r)
    {
        try
        {
            var (downloadTask, ensureResult) = OvertureCache.GetOrStartDownload(r.Iso3!);
            await UpdateLookupStatusAsync(ensureResult switch
            {
                OvertureDivisionEnsureResult.StartedDownload => $"Downloading Overture administrative cache for {r.Iso3}...",
                OvertureDivisionEnsureResult.AwaitedExistingDownload => $"Waiting for Overture administrative cache for {r.Iso3}...",
                _ => $"Overture administrative cache already ready for {r.Iso3}."
            });
            await downloadTask;
            r.OvertureDivisionCacheReady = OvertureCache.HasData(r.Iso3!);
            r.Trace.Add($"Overture division cache ready for {r.Iso3}");
        }
        catch (Exception ex)
        {
            r.Trace.Add($"Overture division cache unavailable: {ex.Message}");
        }
    }

    private async Task EnsureGadmCacheAsync(LookupResult r, IReadOnlyList<string> candidateCodes)
    {
        if (!_preferGadmAdministrativeAreas || r.Iso3 is null)
        {
            return;
        }

        try
        {
            var readyCodes = new List<string>();
            foreach (var iso3 in candidateCodes)
            {
                var (downloadTask, ensureResult) = GadmCache.GetOrStartDownload(iso3);
                await UpdateLookupStatusAsync(ensureResult switch
                {
                    GadmDivisionEnsureResult.StartedDownload => $"Downloading GADM administrative cache for {iso3}...",
                    GadmDivisionEnsureResult.AwaitedExistingDownload => $"Waiting for GADM administrative cache for {iso3}...",
                    _ => $"GADM administrative cache already ready for {iso3}."
                });
                await downloadTask;
                if (GadmCache.HasData(iso3))
                {
                    readyCodes.Add(iso3);
                }
            }

            r.GadmDivisionCacheReady = readyCodes.Count > 0;
            r.Trace.Add(readyCodes.Count > 0
                ? $"GADM division cache ready for {string.Join(", ", readyCodes)}"
                : "GADM division cache unavailable.");
        }
        catch (Exception ex)
        {
            r.Trace.Add($"GADM division cache unavailable: {ex.Message}");
        }
    }

    private Task UpdateLookupStatusAsync(string status)
    {
        _lookupStatus = status;
        return InvokeAsync(StateHasChanged);
    }

    private sealed class LookupResult
    {
        public string? Iso3 { get; set; }
        public string? CountryName { get; set; }
        public string? Alpha2 { get; set; }
        public bool AirportInfrastructureEnabled { get; set; }
        public bool LivePlacesEnabled { get; set; }
        public bool GadmEnabled { get; set; }
        public bool OvertureDivisionCacheReady { get; set; }
        public OvertureDivisionResult? OvertureDivision { get; set; }
        public OvertureDivisionLookupDiagnostics? OvertureDivisionDiagnostics { get; set; }
        public string? OvertureDivisionState { get; set; }
        public string? OvertureDivisionCity { get; set; }
        public bool GadmDivisionCacheReady { get; set; }
        public GadmDivisionResult? GadmDivision { get; set; }
        public GadmDivisionLookupDiagnostics? GadmDivisionDiagnostics { get; set; }
        public string? GadmDivisionState { get; set; }
        public string? GadmDivisionCity { get; set; }
        public OvertureInfrastructureResult? OvertureInfrastructure { get; set; }
        public OvertureInfrastructureLookupDiagnostics? OvertureInfrastructureDiagnostics { get; set; }
        public OverturePlaceResult? OverturePoi { get; set; }
        public OvertureLookupDiagnostics? OvertureDiagnostics { get; set; }
        public string? FinalState { get; set; }
        public string? FinalStateSource { get; set; }
        public string? FinalCity { get; set; }
        public string? FinalCitySource { get; set; }
        public string? FinalCountrySource { get; set; }
        public string? CityResolverSummary { get; set; }
        public List<string> Trace { get; } = [];
    }

    private static string DescribeSources(IReadOnlyList<string> sources)
    {
        return sources.Count == 0 ? "â" : string.Join(", ", sources);
    }

    private static IReadOnlyDictionary<string, object>? GetDetailsAttributes(bool open)
    {
        return open ? new Dictionary<string, object> { ["open"] = "open" } : null;
    }

    private static IEnumerable<OvertureDivisionCandidateDiagnostic> SortDivisionCandidates(
        IEnumerable<OvertureDivisionCandidateDiagnostic> candidates)
    {
        return candidates
            .OrderByDescending(c => c.Selected)
            .ThenByDescending(c => c.GeometryContainsPoint)
            .ThenByDescending(c => c.BoundingBoxContainsPoint)
            .ThenBy(c => OvertureDivisionsLogic.GetSubtypeRank(c.SubType))
            .ThenBy(c => c.AdminLevel ?? int.MaxValue)
            .ThenByDescending(c => c.IsTerritorial)
            .ThenBy(c => c.BoundingBoxArea);
    }

    private static IEnumerable<OvertureInfrastructureCandidateDiagnostic> SortInfrastructureCandidates(
        IEnumerable<OvertureInfrastructureCandidateDiagnostic> candidates)
    {
        return candidates
            .OrderByDescending(c => c.Selected)
            .ThenBy(c => OverturePlacesLogic.GetInfrastructureClassRank(c.SubType, c.ClassName))
            .ThenByDescending(c => c.GeometryContainsPoint)
            .ThenByDescending(c => c.BoundingBoxContainsPoint)
            .ThenBy(c => c.DistanceMetres);
    }

    private static IEnumerable<OvertureCandidateDiagnostic> SortPlaceCandidates(
        IEnumerable<OvertureCandidateDiagnostic> candidates)
    {
        return candidates
            .OrderByDescending(c => c.Selected)
            .ThenByDescending(c => OverturePlacesLogic.IsPreferredStatus(c.OperatingStatus))
            .ThenByDescending(c => c.BoundingBoxContainsPoint)
            .ThenBy(c => c.DistanceMetres);
    }

    private static IEnumerable<GadmDivisionCandidateDiagnostic> SortGadmCandidates(
        IEnumerable<GadmDivisionCandidateDiagnostic> candidates)
    {
        return candidates
            .OrderByDescending(candidate => candidate.Selected)
            .ThenByDescending(candidate => candidate.GeometryContainsPoint)
            .ThenByDescending(candidate => candidate.BoundingBoxContainsPoint)
            .ThenByDescending(candidate => candidate.AdminLevel)
            .ThenBy(candidate => candidate.BoundingBoxArea);
    }
}
